{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "outDir": "./out/types/worker",
    "tsBuildInfoFile": "./out/types/worker.tsbuildinfo",
    // shared/ 用 ES 风格 export,worker 输出 CJS 由编译器转译;关掉 verbatim 才能消费
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/main/workers/**/*.cts",
    "src/main/workers/**/*.ts",
    "shared/**/*.ts",
    "scripts/eval-*.ts",
    "scripts/spike-*.ts"
  ]
}
